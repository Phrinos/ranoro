rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funciones de Ayuda ---
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserPermissions() {
      let roleRef = /databases/$(database)/documents/appRoles/$(getUserData().role);
      return exists(roleRef) ? get(roleRef).data.permissions : [];
    }

    function hasPermission(permission) {
      return isSignedIn() && userDocExists() && (getUserData().role == 'Superadministrador' || permission in getUserPermissions());
    }
    
    function isSuperAdmin() {
      return isSignedIn() && userDocExists() && getUserData().role == 'Superadministrador';
    }
    
    // --- Reglas por Colección ---

    // Usuarios
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSuperAdmin() || hasPermission('admin:manage_users_roles');
      allow update: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin() || hasPermission('admin:manage_users_roles'));
      allow delete: if isSuperAdmin();
    }

    // Roles y Áreas
    match /appRoles/{roleId} {
      allow read: if isSignedIn();
      allow write: if hasPermission('admin:manage_users_roles');
    }
    match /workAreas/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('admin:settings');
    }

    // Vehículos
    match /vehicles/{vehicleId} {
      allow read: if isSignedIn();
      allow write: if hasPermission('vehicles:manage') || hasPermission('fleet:create') || hasPermission('fleet:edit');
    }

    // Conductores y Flotilla
    match /drivers/{driverId} {
      allow read: if isSignedIn();
      allow write: if hasPermission('fleet:manage_drivers');
    }
    match /rentalPayments/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('fleet:manage_rentals');
    }
    match /dailyRentalCharges/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('fleet:manage_rentals');
    }
    match /manualDebts/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('fleet:manage_rentals');
    }
    match /ownerWithdrawals/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('fleet:manage_rentals');
    }
    match /vehicleExpenses/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('fleet:manage_rentals');
    }
    match /fleetMonthlyBalances/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('fleet:manage_rentals');
    }
    match /cashDrawerState/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Inventario
    match /inventory/{itemId} {
      allow read: if hasPermission('inventory:view');
      allow write: if hasPermission('inventory:create') || hasPermission('inventory:edit');
    }
    match /inventoryCategories/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('inventory:manage_categories');
    }
    match /suppliers/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('suppliers:manage');
    }
    match /inventoryMovements/{id} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /serviceTypes/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('admin:settings');
    }
    match /vehicleGroups/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('fleet:view');
    }
    match /masterCatalogData/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('inventory:create');
    }
    match /vehicleData/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('fleet:view');
    }

    // Compras y Cuentas por Pagar
    match /purchases/{id} {
      allow read: if hasPermission('purchases:view');
      allow write: if hasPermission('purchases:create');
    }
    match /payableAccounts/{id} {
      allow read: if hasPermission('purchases:view');
      allow write: if hasPermission('purchases:create');
    }

    // Servicios
    match /serviceRecords/{serviceId} {
      allow read: if isSignedIn();
      allow write: if hasPermission('services:create') || hasPermission('services:edit');
    }
    match /publicServices/{serviceId} {
      allow read: if true;
      allow update: if true;
      allow create, delete: if false;
    }

    // Punto de Venta
    match /sales/{saleId} {
      // Read allowed for any signed-in user so dashboard KPIs can query today's sales
      allow read: if isSignedIn();
      allow write: if hasPermission('pos:create_sale');
    }

    // Caja y Finanzas
    match /cashDrawerTransactions/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /fixedMonthlyExpenses/{id} {
      allow read: if hasPermission('finances:view');
      allow write: if hasPermission('admin:settings');
    }
    match /workshopConfig/{id} {
      allow read: if true;
      allow write: if hasPermission('admin:settings');
    }
    
    // Auditoría
    match /auditLogs/{logId} {
        allow read: if hasPermission('admin:view_audit');
        allow write: if isSignedIn();
    }

    // Sistema / Dashboard Stats (escritura solo desde backend con Admin SDK)
    match /system/{docId} {
      allow read: if isSignedIn();
      allow write: if false; // solo se escribe desde Cloud Functions con Admin SDK
    }
    match /systemStats/{docId} {
      allow read: if isSignedIn();
      allow write: if false; 
    }

    // WhatsApp conversaciones (lectura para notificaciones)
    match /whatsapp-conversations/{id} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Citas (para campana de notificaciones)
    match /appointments/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /spaAppointments/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Denegar por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
