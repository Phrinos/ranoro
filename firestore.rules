rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════
    // FUNCIONES DE AYUDA — Simples, sin lecturas extra innecesarias
    // ═══════════════════════════════════════════════════════════════════

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? getUserData().role
        : '';
    }

    // Roles del sistema:
    //   'Superadministrador' — acceso total
    //   'Asesor'             — operaciones del taller (ventas, servicios, inventario)
    //   'Técnico'            — solo lectura + actualizar servicios asignados

    function isSuperAdmin() {
      return getUserRole() == 'Superadministrador';
    }

    function isStaff() {
      // Superadmin o Asesor — pueden leer y escribir en casi todo
      return getUserRole() == 'Superadministrador' || getUserRole() == 'Asesor';
    }

    function isAnyRole() {
      // Cualquier usuario con rol válido
      let role = getUserRole();
      return role == 'Superadministrador' || role == 'Asesor' || role == 'Técnico';
    }

    // ═══════════════════════════════════════════════════════════════════
    // REGLAS POR COLECCIÓN
    // ═══════════════════════════════════════════════════════════════════

    // ─── Usuarios y Roles ─────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSuperAdmin();
      allow update: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    match /appRoles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /workAreas/{id} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // ─── Operaciones del Taller ───────────────────────────────────────
    // Vehículos, Servicios, Ventas, Inventario, Compras, etc.
    // Cualquier usuario logueado puede LEER.
    // Staff (Super + Asesor) puede ESCRIBIR.
    // Solo Super puede BORRAR datos sensibles.

    match /vehicles/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    match /serviceRecords/{id} {
      allow read: if isSignedIn();
      allow create: if isStaff();
      allow update: if isSignedIn();  // Técnicos pueden actualizar servicios
      allow delete: if isSuperAdmin();
    }

    match /publicServices/{id} {
      allow read: if true;   // Público (clientes ven estado de su servicio)
      allow update: if true; // Los clientes pueden autorizar/firmar
      allow create, delete: if isStaff();
    }

    match /sales/{id} {
      allow read: if isSignedIn();
      allow create, update: if isStaff();
      allow delete: if isSuperAdmin();
    }

    match /inventory/{id} {
      allow read: if isSignedIn();
      allow create, update: if isStaff();
      allow delete: if isSuperAdmin();
    }

    match /inventoryItems/{id} {
      allow read: if isSignedIn();
      allow create, update: if isStaff();
      allow delete: if isSuperAdmin();
    }

    match /inventoryCategories/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    match /inventoryMovements/{id} {
      allow read: if isSignedIn();
      allow create: if isStaff();
      allow update, delete: if isSuperAdmin();
    }

    match /suppliers/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    match /purchases/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    match /payableAccounts/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    match /serviceTypes/{id} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /masterCatalogData/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    // ─── Directorio Vehicular ─────────────────────────────────────────
    match /vehicleData/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    match /vehicleGroups/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    // ─── Flotilla ─────────────────────────────────────────────────────
    match /drivers/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    match /rentalPayments/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    match /dailyRentalCharges/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    match /manualDebts/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    match /ownerWithdrawals/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    match /vehicleExpenses/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    match /fleetMonthlyBalances/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    // ─── Caja y Finanzas ──────────────────────────────────────────────
    match /cashDrawerState/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /cashDrawerTransactions/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /monthlyBalances/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    match /dailyCuts/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    match /fixedExpenses/{id} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /fixedMonthlyExpenses/{id} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // ─── Configuración ────────────────────────────────────────────────
    match /workshopConfig/{id} {
      allow read: if true;  // Público (logo, nombre del taller, etc.)
      allow write: if isSuperAdmin();
    }

    match /settings/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    // ─── Auditoría ────────────────────────────────────────────────────
    match /auditLogs/{id} {
      allow read: if isSuperAdmin();
      allow create: if isSignedIn();    // Cualquier acción genera log
      allow update, delete: if false;   // Los logs son inmutables
    }

    // ─── Sistema ──────────────────────────────────────────────────────
    match /system/{id} {
      allow read: if isSignedIn();
      allow write: if false;  // Solo Cloud Functions
    }

    match /systemStats/{id} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ─── Comunicaciones ───────────────────────────────────────────────
    match /whatsapp-conversations/{id} {
      allow read: if isSignedIn();
      allow write: if false;  // Solo Cloud Functions
    }

    // ─── Citas ────────────────────────────────────────────────────────
    match /appointments/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /spaAppointments/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ─── Denegar por defecto ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
