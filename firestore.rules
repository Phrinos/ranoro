rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funciones de Ayuda ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserPermissions() {
      return get(/databases/$(database)/documents/appRoles/$(getUserData().role)).data.permissions;
    }

    function hasPermission(permission) {
      return isSignedIn() && (permission in getUserPermissions() || getUserData().role == 'Superadministrador');
    }
    
    // --- Reglas por Colección ---

    // Usuarios
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || hasPermission('users:manage'));
    }

    // Roles
    match /appRoles/{roleId} {
      allow read: if isSignedIn();
      allow write: if hasPermission('roles:manage');
    }

    // Vehículos
    match /vehicles/{vehicleId} {
      allow read: if isSignedIn();
      allow write: if hasPermission('vehicles:manage');
    }

    // Conductores y Flotilla
    match /drivers/{driverId} {
      allow read: if isSignedIn();
      allow write: if hasPermission('drivers:create') || hasPermission('fleet:manage');
    }
    match /rentalPayments/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('rentals:manage');
    }
    match /dailyRentalCharges/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('rentals:manage');
    }
    match /manualDebts/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('rentals:manage');
    }
    match /ownerWithdrawals/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('rentals:manage');
    }
    match /vehicleExpenses/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('rentals:manage');
    }

    // Inventario
    match /inventory/{itemId} {
      allow read: if hasPermission('inventory:view_public_info');
      allow write: if hasPermission('inventory:manage');
    }
    match /inventoryCategories/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('inventory:manage');
    }
    match /suppliers/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('inventory:manage');
    }
    match /inventoryMovements/{id} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /serviceTypes/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('roles:manage');
    }
    match /vehicleGroups/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('inventory:manage');
    }
    match /masterCatalogData/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('inventory:manage');
    }
    match /vehicleData/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('inventory:manage');
    }

    // Compras y Cuentas por Pagar
    match /purchases/{id} {
      allow read: if hasPermission('purchases:manage');
      allow write: if hasPermission('purchases:manage');
    }
    match /payableAccounts/{id} {
      allow read: if hasPermission('purchases:manage');
      allow write: if hasPermission('purchases:manage');
    }

    // Servicios
    match /serviceRecords/{serviceId} {
      allow read: if isSignedIn();
      allow write: if hasPermission('services:create') || hasPermission('services:edit');
    }
    match /publicServices/{serviceId} {
      allow read: if true;
      allow update: if true;
      allow create, delete: if false;
    }

    // Punto de Venta
    match /sales/{saleId} {
      allow read: if hasPermission('pos:view_sales');
      allow write: if hasPermission('pos:create_sale');
    }

    // Caja y Finanzas
    match /cashDrawerTransactions/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /fixedMonthlyExpenses/{id} {
      allow read: if hasPermission('finances:view_report');
      allow write: if hasPermission('workshop:manage');
    }
    match /workshopConfig/{id} {
      allow read: if true;
      allow write: if hasPermission('workshop:manage');
    }
    
    // Auditoría
    match /auditLogs/{logId} {
        allow read: if hasPermission('audits:view');
        allow write: if isSignedIn();
    }

    // Denegar por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
