{
  "name": "studio",
  "version": "0.1.0",
  "private": true,
  "description": "Ranoro App",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "genkit:dev": "genkit start -- tsx src/ai/dev.ts",
    "genkit:watch": "genkit start -- tsx --watch src/ai/dev.ts",
    "build": "NODE_ENV=production next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "typecheck:functions": "tsc --noEmit -p functions/tsconfig.json",
    "deploy:rules": "firebase deploy --only firestore:rules,firestore:indexes,storage",
    "deploy:functions": "firebase deploy --only functions",
    "ship": "git add -A && (git diff --cached --quiet || git commit -m \"ship: $(date '+%Y-%m-%d %H:%M')\") && git push && firebase deploy --only functions,firestore:rules,firestore:indexes,storage"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "overrides": {
    "postcss": "^8.5.15",
    "uuid": "^11.1.1"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.6.0",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.4.0",
    "@iconify/react": "^6.0.2",
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slider": "^1.4.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-toast": "^1.2.17",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@react-pdf/renderer": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "facturapi": "^4.18.0",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.1.0",
    "firebase-functions": "^7.2.5",
    "framer-motion": "^12.42.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.21.0",
    "nanoid": "^5.1.16",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-calendar": "^6.0.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-image-crop": "^11.1.2",
    "react-is": "^19.2.7",
    "react-signature-canvas": "^1.0.7",
    "react-to-print": "^3.3.0",
    "recharts": "^3.9.0",
    "server-only": "^0.0.1",
    "sharp": "^0.35.2",
    "tailwind-merge": "^3.6.0",
    "use-debounce": "^10.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.9",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/tough-cookie": "^4.0.5",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-config-next": "^16.2.9",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "lightningcss": "^1.32.0",
    "postcss": "^8.5.15",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
